# Core output path
AUTORAG_ARTIFACT_ROOT=data/artifacts

# Demo-build overrides
AUTORAG_DEMO_RUN_ID=m6
AUTORAG_DEMO_INPUT_DIR=data/fixtures/pdfs
AUTORAG_DEMO_QUESTION=Compare mitigation and acceptance strategies.
AUTORAG_DEMO_MODE=hybrid
AUTORAG_DEMO_TOP_K=8
AUTORAG_DEMO_REPORTS_DIR=reports/milestones
AUTORAG_DEMO_MATRIX_REPORTS_DIR=reports/experiments

# Embedding + reranker provider settings
AUTORAG_EMBEDDING_PROVIDER=local_hash
AUTORAG_EMBEDDING_MODEL=bge-small-en-v1.5
AUTORAG_RERANKER_ENABLED=false
AUTORAG_RERANKER_MODEL=llama3:8b
AUTORAG_RERANKER_CANDIDATE_K=30
AUTORAG_ANSWER_USE_LOCAL=false
AUTORAG_ANSWER_MODEL=llama3
AUTORAG_ANSWER_TEMPERATURE=0.2
AUTORAG_ANSWER_MAX_TOKENS=512
AUTORAG_CITATION_SUPPORT_LEXICAL_WEIGHT=0.7
AUTORAG_CITATION_SUPPORT_HIT_WEIGHT=0.3
AUTORAG_CITATION_SUPPORT_FLOOR=0.001
AUTORAG_OLLAMA_BASE_URL=http://localhost:11434
AUTORAG_OLLAMA_TIMEOUT_SECONDS=30
# Ollama Cloud API key for remote model access (optional)
# OLLAMA_API_KEY=
